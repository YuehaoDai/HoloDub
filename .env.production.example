# HoloDub production-oriented example configuration.
# HoloDub 面向生产的示例配置。
#
# Copy this file only when you are ready to switch to real backends.
# 只有在你准备切换到真实后端时，才建议以本文件为基础复制为 .env。

APP_NAME=HoloDub
APP_ENV=production
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json
DATA_ROOT=/data

DATABASE_DRIVER=postgres
DATABASE_DSN=host=postgres user=holodub password=holodub dbname=holodub port=5432 sslmode=disable TimeZone=UTC
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
QUEUE_KEY=holodub:tasks
DELAYED_QUEUE_KEY=holodub:tasks:delayed
DEAD_LETTER_QUEUE_KEY=holodub:tasks:dead
STAGE_LEASE_PREFIX=holodub:lease
WORKER_ID=holodub-worker
WORKER_POLL_SECONDS=5
STAGE_TIMEOUT_SECONDS=1800
STAGE_LEASE_TTL_SECONDS=3600
MAX_JOB_RETRIES=3
RETRY_BASE_DELAY_MS=3000
DEFAULT_TENANT_KEY=default

API_AUTH_TOKEN=replace-with-a-strong-api-token
TRUSTED_PROXIES=
REQUEST_RATE_LIMIT_RPS=5
REQUEST_RATE_LIMIT_BURST=20
ENABLE_METRICS=true
NOTIFICATION_TIMEOUT_SECONDS=10
MODEL_MANIFEST_PATH=/app/config/model-manifest.example.json
AUTO_MIGRATE_ON_START=true

ML_SERVICE_URL=http://ml-service:8000

TRANSLATION_PROVIDER=openai_compatible
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace-with-real-key
OPENAI_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_SECONDS=120

FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

ML_SEPARATOR_BACKEND=demucs
ML_ASR_BACKEND=faster_whisper
ML_VAD_BACKEND=pyannote
ML_TTS_BACKEND=indextts2
GPU_CONCURRENCY=1
FASTER_WHISPER_MODEL=large-v3
PYANNOTE_AUTH_TOKEN=replace-with-real-token
PYANNOTE_PIPELINE=pyannote/speaker-diarization-3.1
INDEXTTS2_ENDPOINT=
INDEXTTS2_API_KEY=
INDEXTTS2_MODEL=replace-with-production-model
INDEXTTS2_COMMAND=
DEFAULT_SAMPLE_RATE=24000
DEFAULT_CHANNELS=1
ML_PYTHON_EXTRAS=real
