# Production .env example — DO NOT commit a populated copy of this file.
#
# Generate a strong API token before deploy:
#   openssl rand -hex 32 > secrets/api_auth_token.txt
# and a separate Postgres password into secrets/postgres_password.txt.
#
# This file documents the env variables themselves; the secrets that should
# never appear in plain env are loaded from Docker secrets in
# docker-compose.prod.yml.

APP_NAME=HoloDub
APP_ENV=production
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=json
DATA_ROOT=/data

# Postgres / Redis hostnames inside the compose network.
DATABASE_DRIVER=postgres
DATABASE_DSN=host=postgres user=holodub dbname=holodub port=5432 sslmode=disable TimeZone=UTC
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

QUEUE_KEY=holodub:tasks
DELAYED_QUEUE_KEY=holodub:tasks:delayed
DEAD_LETTER_QUEUE_KEY=holodub:tasks:dead
STAGE_LEASE_PREFIX=holodub:lease

# Migrations should be run as a one-shot job, not on every startup.
AUTO_MIGRATE_ON_START=false

# Worker pool — tune for your hardware.
TTS_CONCURRENCY=2
GPU_CONCURRENCY=2
WORKER_POLL_SECONDS=2
STAGE_TIMEOUT_SECONDS=14400
STAGE_LEASE_TTL_SECONDS=1800
MAX_JOB_RETRIES=3
RETRY_BASE_DELAY_MS=2000

# API security — token loaded from secrets file, not this env.
# API_AUTH_TOKEN=__file:/run/secrets/api_auth_token  # if you adopt loadenv-from-file
TRUSTED_PROXIES=127.0.0.1
REQUEST_RATE_LIMIT_RPS=20
REQUEST_RATE_LIMIT_BURST=50
ENABLE_METRICS=true

# Translation provider.
TRANSLATION_PROVIDER=openai_compatible
OPENAI_BASE_URL=https://api.deepseek.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=deepseek-chat

# Real ML backends.
ML_PYTHON_EXTRAS=real
ML_ASR_BACKEND=faster_whisper
FASTER_WHISPER_MODEL=large-v3
ML_TTS_BACKEND=indextts2
INDEXTTS2_INLINE=true
INDEXTTS2_USE_EMO_TEXT=true
ML_VAD_BACKEND=none

ML_SERVICE_URL=http://ml-service:8000

# Notifications.
NOTIFICATION_TIMEOUT_SECONDS=10
DEFAULT_TENANT_KEY=default

# OPT-403 chapterize / OPT-404 episode_merge — production defaults.
# Long-form content (>= 30 min) is auto-split into 18–30 min chapters,
# titled by the chapter-review LLM, and re-stitched into a single final
# episode video with EBU R128 normalisation. Disable individual flags
# only when investigating a regression. See .env.example for full docs.
CHAPTERIZE_ENABLED=true
CHAPTERIZE_MIN_CHAPTER_MS=1080000
CHAPTERIZE_TARGET_CHAPTER_MS=1320000
CHAPTERIZE_MAX_CHAPTER_MS=1800000
CHAPTERIZE_MIN_SILENCE_GAP_MS=800
CHAPTER_REVIEW_LLM_ENABLED=true
CHAPTER_REVIEW_MODEL=
# OPT-405 LLM-driven chapter cuts (default on; preferred over the DP
# algorithm above for talks / lectures / podcasts). Set GLOSSARY_MODEL
# to kimi-k2.5 (or another long-context strong-reasoning model) to make
# the most of this path.
CHAPTERIZE_LLM_DRIVEN=true
CHAPTERIZE_HARD_MAX_MS=2700000
CHAPTERIZE_HARD_MIN_MS=300000
# OPT-409 chapter-level judge (observe-only). Empty disables.
CHAPTER_JUDGE_MODEL=kimi-k2.5
CHAPTER_JUDGE_OBSERVE_ONLY=true
# OPT-002-followup-2 worker startup judge backfill.
JUDGE_BACKFILL_ON_START=true
JUDGE_BACKFILL_LIMIT=500
LOUDNORM_TARGET_I=-23.0
LOUDNORM_TARGET_TP=-1.0
LOUDNORM_TARGET_LRA=7.0
LOUDNORM_CHAPTER_ENABLED=true
LOUDNORM_MASTER_ENABLED=true
EPISODE_MERGE_ENABLED=true
