# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env
.venv/
.venv-smoke/

# Python cache / build outputs
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
dist/
build/
*.egg-info/

# Runtime data and job outputs
data/jobs/
data/tmp/
data/cache/
data/voices/
data/debug-*.log

# Cursor IDE
.cursor/

# Test / scratch videos in data/ (large, runtime-generated, not versioned)
data/test_*.mp4
data/test_*.mkv
data/input-smoke*.mp4

# HuggingFace model cache (large files, populated at runtime)
hf-cache/

# Video files are not committed to the repository
*.mp4
*.mkv
*.webm
*.avi

# Secrets and local tokens
token.txt

# Local tooling / scratch files
.DS_Store
query

# Local developer notes — not committed
docs/system-overview.md
docs/*.local.md

# Scratch files
query
token.txt

# Temp test outputs in root
test_output_*.mp4

# Node.js / frontend build artifacts
ui/node_modules/
ui/.vite/

# Editor/IDE
# .idea/
# .vscode/
