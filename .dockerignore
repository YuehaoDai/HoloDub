# Model caches — several GB, not needed inside the build container
hf-cache/

# Runtime data (exclude whole tree — partial ignores still let huge files under data/ into context)
data/

# Frontend deps — not used by Go/ml Dockerfiles but bloats compose build context
ui/node_modules/

# Demo videos
demo/

# Git and editor metadata
.git/
.venv/
.venv-smoke/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# Secrets
.env
token.txt

# Cross-compiled Linux binaries (hot-update artifacts; not needed inside images)
holodub-api-linux
holodub-worker-linux

# Local tooling
query
*.test
*.out
coverage.*
