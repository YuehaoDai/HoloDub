# Quick start / 快速开始
# 1) Copy this file to .env. / 先复制本文件为 .env
# 2) For a smoke run, keep the defaults below. / 如果只是烟测，保留下面默认值即可
# 3) Start with: docker compose up --build -d / 启动命令：docker compose up --build -d
#
# Common modes / 常见模式
# - Smoke run / 烟测模式:
#   keep TRANSLATION_PROVIDER=mock, ML_SEPARATOR_BACKEND=ffmpeg_stub,
#   ML_ASR_BACKEND=mock, ML_VAD_BACKEND=none, ML_TTS_BACKEND=silence
# - Real translation only / 只接真实翻译:
#   set TRANSLATION_PROVIDER=openai_compatible and fill
#   OPENAI_BASE_URL / OPENAI_API_KEY / OPENAI_MODEL
# - Real ML backends / 接入真实 ML 后端:
#   set ML_PYTHON_EXTRAS=real, rebuild the ml-service image,
#   then switch ML_*_BACKEND values and fill the matching fields below

# General service settings used by the Go API / worker.
# Go API / Worker 的通用服务配置。
APP_NAME=HoloDub
APP_ENV=development
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=text

# Shared storage mounted into all containers.
# 所有容器共享的数据目录；使用 Docker Compose 时保持 /data。
DATA_ROOT=/data

# Database and queue used by the Go control plane.
# Go 控制面使用的数据库和队列。
# Keep these defaults for docker compose.
# 使用 compose 时保留默认值；只有外接 postgres / redis 时才需要改。
DATABASE_DRIVER=postgres
DATABASE_DSN=host=postgres user=holodub password=holodub dbname=holodub port=5432 sslmode=disable TimeZone=UTC
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
QUEUE_KEY=holodub:tasks
DELAYED_QUEUE_KEY=holodub:tasks:delayed
DEAD_LETTER_QUEUE_KEY=holodub:tasks:dead
STAGE_LEASE_PREFIX=holodub:lease
WORKER_ID=holodub-worker
WORKER_POLL_SECONDS=5
STAGE_TIMEOUT_SECONDS=900
STAGE_LEASE_TTL_SECONDS=1800
MAX_JOB_RETRIES=3
RETRY_BASE_DELAY_MS=2000
DEFAULT_TENANT_KEY=default

# API security and observability / API 安全与可观测性
# Leave API_AUTH_TOKEN empty for local smoke tests.
# 本地烟测可留空 API_AUTH_TOKEN；生产环境建议必须设置。
API_AUTH_TOKEN=
# Comma-separated trusted proxy list, for example:
# 逗号分隔的可信代理列表，例如：
# TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8
TRUSTED_PROXIES=
# 本地开发建议放宽，避免频繁触发限流（Job 详情页单次加载约 6 个请求）
REQUEST_RATE_LIMIT_RPS=20
REQUEST_RATE_LIMIT_BURST=50
ENABLE_METRICS=true
NOTIFICATION_TIMEOUT_SECONDS=10
MODEL_MANIFEST_PATH=/app/config/model-manifest.example.json
# Only one service should run DB migrations in production.
# 生产环境中建议只有一个服务负责执行数据库迁移。
AUTO_MIGRATE_ON_START=true

# Downstream service URLs used by the Go worker.
# Go Worker 调用下游服务时使用的地址。
ML_SERVICE_URL=http://ml-service:8000

# Translation settings / 翻译配置
# TRANSLATION_PROVIDER options / 可选值:
# - mock: no external API required; best for smoke tests
#   不需要外部翻译 API，最适合先跑通流程
# - openai_compatible: requires OPENAI_BASE_URL, OPENAI_API_KEY, OPENAI_MODEL
#   使用 OpenAI 兼容接口，必须填写下面三个字段
TRANSLATION_PROVIDER=mock
# Example OPENAI_BASE_URL values / OPENAI_BASE_URL 示例:
# - https://api.openai.com/v1
# - your OpenAI-compatible gateway / proxy / self-hosted endpoint ending in /v1
# - 你自己的兼容 OpenAI 的网关 / 代理 / 自部署地址，通常以 /v1 结尾
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
# Lower temperature is usually better for stable, length-aware translation.
# 温度越低通常越稳定，也更适合长度可控的翻译。
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_SECONDS=90

# Duration-aware re-translation: when TTS output drifts too far from the target,
# HoloDub calls a dedicated model to produce a tighter translation before retrying TTS.
# Reuses OPENAI_BASE_URL and OPENAI_API_KEY.
# Set RETRANSLATION_ENABLED=false to disable the loop and fall back to atempo only.
RETRANSLATION_ENABLED=true
# Relative drift that triggers re-translation (0.06 = 6%). Must be <= this to pass.
RETRANSLATION_DRIFT_THRESHOLD=0.06
# Absolute drift cap in seconds. Effective threshold = min(DRIFT_THRESHOLD, ABS_MAX/targetSec).
# Prevents long segments from having large absolute sync errors (e.g. 5% × 23s = 1.15s).
# Set to 0 to disable and rely only on the relative threshold.
RETRANSLATION_ABS_MAX_DRIFT_SEC=0.8
# Minimum relative threshold floor (prevents impossibly strict targets for very long segments).
# e.g. 0.03 means the effective threshold never goes below 3% regardless of segment length.
RETRANSLATION_MIN_DRIFT_THRESHOLD=0.03
# Maximum re-translation attempts per segment before accepting the result (up to 10).
RETRANSLATION_MAX_ATTEMPTS=10
# Model name for the re-translation agent. Must be available on OPENAI_BASE_URL.
RETRANSLATION_MODEL=kimi-k2.5
# Trigger thinking mode after N consecutive attempts without drift improvement (oscillation/non-convergence).
RETRANSLATION_NON_CONVERGENCE_WINDOW=3
# For pipeline-triggered (initial) synthesis: more attempts and a stricter threshold.
RETRANSLATION_INITIAL_MAX_ATTEMPTS=50
RETRANSLATION_INITIAL_ABS_MAX_DRIFT_SEC=0.75
# Exponential moving average weight for voice profile speaking-rate calibration (0–1).
VOICE_PROFILE_RATE_ALPHA=0.3

# Runtime tools expected inside the container images.
# 容器内预期存在的运行工具。
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# ML service backend selection / ML 服务后端选择
# ML_SEPARATOR_BACKEND options / 可选值:
# - ffmpeg_stub: only prepares / extracts audio; no real vocal separation
#   只做音频准备 / 提取，不做人声伴奏真实分离
# - demucs: real vocal / BGM separation; requires ML_PYTHON_EXTRAS=real
#   真实人声 / 伴奏分离，需要安装 heavy 依赖
ML_SEPARATOR_BACKEND=ffmpeg_stub
# ML_ASR_BACKEND options / 可选值:
# - mock: placeholder transcription or sidecar-driven text for smoke tests
#   占位转写；适合烟测或配合 sidecar 文本
# - faster_whisper: real ASR with word timestamps; requires ML_PYTHON_EXTRAS=real
#   真实 ASR，支持词级时间戳
ML_ASR_BACKEND=mock
# ML_VAD_BACKEND options / 可选值:
# - none: disable pyannote / 不启用 pyannote
# - pyannote: real diarization / VAD; requires ML_PYTHON_EXTRAS=real and token
#   真实说话人分离 / VAD，需要 token
ML_VAD_BACKEND=none
# ML_TTS_BACKEND options / 可选值:
# - silence: write silent placeholder wav files / 生成静音占位 wav
# - indextts2: zero-shot voice clone with duration control / 零样本音色克隆，带时长控制
ML_TTS_BACKEND=silence

# Limit concurrent ML work in the Python service.
# Python ML 服务允许的并发任务数；显存紧张时建议保持 1。
# 2 可提升 TTS 吞吐（需 ~16GB 显存）
GPU_CONCURRENCY=1
# Worker 端 TTS 并发数（同时向 ml-service 发送的请求数）
TTS_CONCURRENCY=2

# Used only when ML_ASR_BACKEND=faster_whisper.
# 仅在 faster_whisper 模式下生效。
FASTER_WHISPER_MODEL=small

# Used only when ML_VAD_BACKEND=pyannote.
# 仅在 pyannote 模式下生效。
PYANNOTE_AUTH_TOKEN=
PYANNOTE_PIPELINE=pyannote/speaker-diarization-3.1

# Used only when ML_TTS_BACKEND=indextts2.
# 仅在 indextts2 模式下生效。
#
# Three integration modes (choose one) / 三种集成方式（三选一）:
#
# 1. Inline mode (recommended for local GPU) / 内联模式（推荐，直接在 ml-service 进程内加载模型）:
#    Set INDEXTTS2_INLINE=true; requires ML_PYTHON_EXTRAS=real and GPU.
#    设置 INDEXTTS2_INLINE=true，需要 ML_PYTHON_EXTRAS=real 且容器能访问 GPU。
INDEXTTS2_INLINE=false
# Path to local model checkpoints directory.
# 本地模型检查点目录路径；留空则首次运行时自动从 HuggingFace 下载。
INDEXTTS2_MODEL_DIR=
# Attention backend for the inline model / 内联模型的注意力后端:
# - empty/sdpa: PyTorch built-in (default, no extra deps) / 默认 PyTorch SDPA，无需额外依赖
# - sage: SageAttention, may help on Ampere/Hopper GPUs / 适合 Ampere/Hopper GPU 提速
# - flash: Flash Attention v2 with paged KV cache / Flash Attn v2，含 KV 缓存加速
INDEXTTS2_ATTN_BACKEND=
# Auto-infer emotion from translated text (Qwen3 fine-tune, requires model download).
# 自动从翻译文本推断情感向量（需要 Qwen3 微调模型，首次运行会额外下载）。
# Set to false to skip emotion inference and use neutral prosody.
# 设置为 false 可跳过情感推断，使用中性语调。
INDEXTTS2_USE_EMO_TEXT=true
# Fallback spk_audio_prompt when no VoiceProfile is bound to a speaker.
# 当某个说话人未绑定 VoiceProfile 时使用的兜底参考音频（相对 DATA_ROOT 的路径）。
# Example: voices/default_speaker.wav
INDEXTTS2_DEFAULT_VOICE_RELPATH=
#
# 2. HTTP mode: run IndexTTS2 as a sidecar service / HTTP 模式：将 IndexTTS2 作为旁路服务运行:
INDEXTTS2_ENDPOINT=
INDEXTTS2_API_KEY=
INDEXTTS2_MODEL=
#
# 3. Command mode: call a local script / 命令模式：调用本地脚本:
# Example template (placeholders filled at runtime) / 示例命令模板（运行时自动填充占位符）:
# python run_tts.py --text "{text}" --duration "{duration}" --output "{output}"
INDEXTTS2_COMMAND=

# Default audio settings for generated / intermediate wav files.
# 生成音频和中间 wav 文件的默认采样设置。
DEFAULT_SAMPLE_RATE=24000
DEFAULT_CHANNELS=1

# Segment review: after asr_smart, an LLM agent scans segments and proposes merges.
# The job then enters awaiting_review status until the user confirms or retries ASR.
# 语义分段后的 LLM 审核：自动提出合并建议，阻塞等待用户确认分段后才继续翻译。
SEGMENT_REVIEW_ENABLED=true
# Model used for review suggestions; falls back to RETRANSLATION_MODEL then OPENAI_MODEL.
# 审核建议使用的模型；为空时依次回落到 RETRANSLATION_MODEL、OPENAI_MODEL。
SEGMENT_REVIEW_MODEL=

# OPT-403 chapterize / fan-out / OPT-404 episode_merge.
# OPT-403 自动章节切分 / 扇出 / OPT-404 章节合并。
#
# When ChapterizeEnabled=true, after ep_glossary_extract the worker runs a
# 3-pass DP over ASR segment silence gaps and (when the episode is long
# enough) splits the source media into N sibling Job rows. Each chapter
# then runs the rest of the per-job pipeline independently. After every
# chapter completes, ep_episode_merge stitches them back into one
# episode-level final.mp4 + chapters.json under the unified layout
# (episodes/{ep_id}/...).
#
# Set CHAPTERIZE_ENABLED=false to keep the legacy 1-job-per-episode
# behaviour. The 138 historical jobs continue to work either way; the
# back-fill tool (cmd/migrate-output) lifts them into the new layout
# without re-encoding.
CHAPTERIZE_ENABLED=true
# Min / target / max chapter duration in milliseconds. The DP penalises
# deviation from the target and rejects any cut that would produce a
# chapter < min or > max. Defaults: 18 / 22 / 30 minutes.
# 章节最短 / 目标 / 最长时长（毫秒），DP 偏离目标越多惩罚越大；超出范围的切点直接被拒。
CHAPTERIZE_MIN_CHAPTER_MS=1080000
CHAPTERIZE_TARGET_CHAPTER_MS=1320000
CHAPTERIZE_MAX_CHAPTER_MS=1800000
# Minimum silence gap (ms) between two ASR segments before we'll consider
# the gap as a chapter-boundary candidate. Smaller = more candidates =
# more LLM-review work in Pass 3. Also used as the snap threshold by
# the OPT-405 LLM-driven path (a snap target must beat this width).
# 章节切点候选所需的最短静音间隔（毫秒），值越小切点候选越多。
CHAPTERIZE_MIN_SILENCE_GAP_MS=800

# OPT-405 LLM-driven chapterization. When true (default), the chapter
# cuts are decided by the SAME LLM call that produces the glossary
# (see GLOSSARY_MODEL — recommended: kimi-k2.5 for long context +
# strong reasoning). The pipeline then snaps each suggested cut to the
# nearest natural silence and enforces hard min/max guardrails. When
# false, falls back to the OPT-403 deterministic DP algorithm above.
# Operators with very short / heavily-edited episodes (eg. trailers)
# may prefer the DP path; for talks / lectures / podcasts the LLM
# path produces materially better cuts (see baseline-opt403 vs the
# OPT-405 review report).
# OPT-405：是否由 LLM 决定章节切分。默认 true（强推理模型按主题切，再 snap 到 silence、强制软上下限）；
# 关闭则回落到 OPT-403 的确定性 DP 算法。
CHAPTERIZE_LLM_DRIVEN=true
# Hard upper bound on a single chapter even when the LLM decided
# otherwise. Anything longer is force-cut at the nearest silence to the
# midpoint (recursive up to depth 4). Default 45min.
# 单章硬上限，超过则在中点附近最近的 silence 上强切。
CHAPTERIZE_HARD_MAX_MS=2700000
# Hard lower bound. Any LLM-emitted chapter shorter than this is merged
# into its successor. Default 5min — short enough not to fight intentional
# brief intros / outros, long enough to filter model hallucinations.
# 单章硬下限，过短则与后一章合并（最后一章则与前一章合并）。
CHAPTERIZE_HARD_MIN_MS=300000

# OPT-403 Pass 3: optional LLM-driven chapter cut review + bilingual title.
# When CHAPTER_REVIEW_LLM_ENABLED=true, the algorithmic cuts are sent to
# an LLM that emits a verdict + bilingual chapter title + summary per cut.
# Chapter titles surface in chapters.json and the UI; setting this flag
# to false yields generic "Chapter N" / "第 N 章" titles instead.
# 章节切分 LLM 审核：通过则生成中英双语标题与摘要；关闭则使用通用占位标题。
CHAPTER_REVIEW_LLM_ENABLED=true
# Override model for the chapter-review agent. Falls back to
# RETRANSLATION_MODEL then OPENAI_MODEL when empty.
# 章节审核所用模型，为空时回落到 RETRANSLATION_MODEL → OPENAI_MODEL。
CHAPTER_REVIEW_MODEL=

# OPT-409 chapter-level judge. After each chapter's runMerge persists the
# Job, an asynchronous LLM call scores it on 6 cross-segment axes (narrative
# coherence, speaker voice stability, terminology consistency, register
# consistency, overall fidelity, overall fluency) plus a top-3-weakest
# segment list and a verdict (chapter_ready / needs_revision /
# needs_major_rework). Results land on jobs.chapter_judge_score and
# jobs.chapter_judge_meta and are surfaced on the chapter cards in the
# Episode detail UI. Empty value disables the chapter judge entirely.
# Recommended: kimi-k2.5 (~$0.005 / chapter at ~3k input tokens, supports
# strict tool calls — thinking models like kimi-k2-thinking auto-degrade
# tool_choice to "auto").
# OPT-409 章级 judge：每个 chapter 合并后异步评分（7 维 + 弱段 + verdict），
# 结果写入 jobs.chapter_judge_score / chapter_judge_meta，UI 章节卡上显示。
# 留空则禁用；推荐 kimi-k2.5。
CHAPTER_JUDGE_MODEL=kimi-k2.5
# OPT-409 MVP observe-only: true = 仅记录评分，不影响任何下游决策。
# OPT-407 闭环 rework 上线后会在标注校准之后翻成 false。
CHAPTER_JUDGE_OBSERVE_ONLY=true

# OPT-406 episode 级 judge：episode_merge 完成后异步评分整集（7 维：跨章
# terminology / register / narrative / character voice / cultural /
# overall fidelity / overall fluency + 弱 chapter 列表 + 弱 segment 列表
# + verdict）。结果写入 episodes.episode_judge_score / episode_judge_meta，
# UI episode header 显示 badge + tooltip。留空则禁用；推荐 kimi-k2.5。
EPISODE_JUDGE_MODEL=kimi-k2.5
# OPT-406 MVP observe-only: true = 仅记录评分，不影响任何下游决策。
# OPT-407 闭环 rework 上线后会在标注校准之后翻成 false。
EPISODE_JUDGE_OBSERVE_ONLY=true
# OPT-406 异步 judge goroutine 的 per-call 截止时间（秒）。episode prompt
# 比 chapter prompt 大（reference card + glossary + chapter overview +
# 全部 segments），thinking 模型典型 20-40s；默认 90 给 ~2x 余量。
EPISODE_JUDGE_TIMEOUT_SEC=90
# OPT-406-followup-2 escalate 模型挂钩。空 = 单模型模式（始终用
# EPISODE_JUDGE_MODEL）。后续 follow-up 上线时会在 chapter judge 平均
# < 0.9 自动切到此模型；当前留空即可，配置该值不会改变 MVP 行为。
EPISODE_JUDGE_ESCALATE_MODEL=

# OPT-002-followup-2 worker startup judge backfill. When true (default),
# the worker scans for synthesised segments that never received a
# segment-level judge verdict and dispatches them through the same
# observe-only goroutine that runs at synthesis time. Closes the gap
# where segments synthesised during a worker restart window stay
# permanently unjudged → judged_ratio sinks → OPT-409 / OPT-407 lose
# correlation data. Bounded by JUDGE_BACKFILL_LIMIT to cap startup cost.
# OPT-002-followup-2：worker 启动时 backfill 未评分的 synthesized 段。
JUDGE_BACKFILL_ON_START=true
# Cap on segments scanned per worker boot. 500 keeps the wakeup-time
# judge cost ≤ ~$0.25 with qwen-turbo (typical ~500 tokens/segment).
# 启动 backfill 单次扫描上限，500 段对应约 $0.25 (qwen-turbo)。
JUDGE_BACKFILL_LIMIT=500

# EBU R128 loudness normalisation targets passed to the two-pass ffmpeg
# loudnorm filter. The defaults mirror EBU R128 / streaming-platform
# expectations (-23 LUFS integrated, -1 dBTP true peak, 7 LU range).
# Touch only if you need a non-broadcast loudness target.
# EBU R128 响度归一化目标：默认值符合 EBU R128 / 流媒体平台规范。
LOUDNORM_TARGET_I=-23.0
LOUDNORM_TARGET_TP=-1.0
LOUDNORM_TARGET_LRA=7.0
# Run loudnorm at the chapter level (during stage_merge). Normalises the
# dub track BEFORE muxing into final.mp4 so chapter-to-chapter loudness
# is consistent regardless of source mix.
# 在 stage_merge 中对每个章节的混音音轨做响度归一化，保证章节间响度一致。
LOUDNORM_CHAPTER_ENABLED=true
# Run a master loudnorm pass over the concatenated episode in
# ep_episode_merge. Skipped automatically for 1-chapter episodes (the
# chapter-level pass already shaped the audio).
# 在 ep_episode_merge 阶段对合并后的整集再做一次响度归一化（单章节会自动跳过）。
LOUDNORM_MASTER_ENABLED=true

# OPT-404 master switch. When false, ep_episode_merge is skipped and
# 1-chapter episodes are marked Completed via the legacy shortcut
# (Episode.OutputRelPath stays empty and the UI falls back to chapter-
# level downloads). Disable only when debugging the chapter pipeline in
# isolation.
# OPT-404 总开关：关闭后 ep_episode_merge 不会触发，单章节走旧分支兜底。
EPISODE_MERGE_ENABLED=true

# OPT-407 closed-loop rework engine. Selects the highest level at which
# the rework engine actually dispatches retry / glossary-broadcast /
# escalation actions after a judge verdict; lower levels still record
# the decision into episodes.rework_attempts as observe-only attempts.
# OPT-407 闭环 rework 引擎：选择最高的自动执行级别。低于该级别的判定仅记录
# 到 episodes.rework_attempts 作为 observe-only 审计，不真正派发动作。
# 取值（顺序覆盖，下面包含上面）：
# - none     : 全关，三层 judge 仍 observe-only（默认，向后兼容）
# - segment  : 仅段级 verdict=retry 触发 RetryJob 重跑
# - chapter  : 段级 + chapter 级 verdict=needs_revision 触发 top3 段重译
# - episode  : 全开 + episode 级 needs_minor_revision 触发 glossary broadcast
REWORK_ENGINE_LEVEL=none
# OPT-407 单 episode 累计 LLM 成本上限（USD）。一旦该 episode 因 rework
# 调用 LLM 累计超过此金额，引擎拒绝后续派发并把
# episodes.rework_status 设为 halted_cost，需运维介入。MVP 默认 2 USD，
# 与典型整集 OPT-401 + OPT-406 端到端成本相当。
EPISODE_REWORK_COST_CEILING_USD=2.0
# OPT-407 段级 verdict=retry 的最大 RetryJob 次数。超过后引擎升级为
# escalate_to_thinking 并最终 accept_with_borrow 兜底。
SEGMENT_RETRY_MAX_ATTEMPTS=3
# OPT-407 chapter 级 needs_revision 的最大重译轮次。超过后升级为
# escalate_chapter（episodes.rework_status='escalated_chapter'）。
CHAPTER_REWORK_MAX_ROUNDS=1
# OPT-407 oscillation 检测阈值：同一 target 连续 N 次返回相同 verdict
# 视为震荡，引擎跳过派发并升级 escalated_oscillation。
REWORK_OSCILLATION_THRESHOLD=2

# Docker build toggle for optional heavy Python dependencies.
# Docker 构建时用于控制是否安装重型 Python 依赖。
# - empty: lightweight image for smoke tests
#   空值：轻量镜像，适合烟测
# - real: installs model-related packages such as demucs / faster-whisper / pyannote
#   real：安装 demucs / faster-whisper / pyannote 等真实模型依赖
# If you change this value, rebuild the ml-service image.
# 修改这个值后，需要重新构建 ml-service 镜像。
ML_PYTHON_EXTRAS=
