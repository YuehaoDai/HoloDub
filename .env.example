# Quick start / 快速开始
# 1) Copy this file to .env. / 先复制本文件为 .env
# 2) For a smoke run, keep the defaults below. / 如果只是烟测，保留下面默认值即可
# 3) Start with: docker compose up --build -d / 启动命令：docker compose up --build -d
#
# Common modes / 常见模式
# - Smoke run / 烟测模式:
#   keep TRANSLATION_PROVIDER=mock, ML_SEPARATOR_BACKEND=ffmpeg_stub,
#   ML_ASR_BACKEND=mock, ML_VAD_BACKEND=none, ML_TTS_BACKEND=silence
# - Real translation only / 只接真实翻译:
#   set TRANSLATION_PROVIDER=openai_compatible and fill
#   OPENAI_BASE_URL / OPENAI_API_KEY / OPENAI_MODEL
# - Real ML backends / 接入真实 ML 后端:
#   set ML_PYTHON_EXTRAS=real, rebuild the ml-service image,
#   then switch ML_*_BACKEND values and fill the matching fields below

# General service settings used by the Go API / worker.
# Go API / Worker 的通用服务配置。
APP_NAME=HoloDub
APP_ENV=development
HTTP_ADDR=:8080
LOG_LEVEL=info
LOG_FORMAT=text

# Shared storage mounted into all containers.
# 所有容器共享的数据目录；使用 Docker Compose 时保持 /data。
DATA_ROOT=/data

# Database and queue used by the Go control plane.
# Go 控制面使用的数据库和队列。
# Keep these defaults for docker compose.
# 使用 compose 时保留默认值；只有外接 postgres / redis 时才需要改。
DATABASE_DRIVER=postgres
DATABASE_DSN=host=postgres user=holodub password=holodub dbname=holodub port=5432 sslmode=disable TimeZone=UTC
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0
QUEUE_KEY=holodub:tasks
DELAYED_QUEUE_KEY=holodub:tasks:delayed
DEAD_LETTER_QUEUE_KEY=holodub:tasks:dead
STAGE_LEASE_PREFIX=holodub:lease
WORKER_ID=holodub-worker
WORKER_POLL_SECONDS=5
STAGE_TIMEOUT_SECONDS=900
STAGE_LEASE_TTL_SECONDS=1800
MAX_JOB_RETRIES=3
RETRY_BASE_DELAY_MS=2000
DEFAULT_TENANT_KEY=default

# API security and observability / API 安全与可观测性
# Leave API_AUTH_TOKEN empty for local smoke tests.
# 本地烟测可留空 API_AUTH_TOKEN；生产环境建议必须设置。
API_AUTH_TOKEN=
# Comma-separated trusted proxy list, for example:
# 逗号分隔的可信代理列表，例如：
# TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8
TRUSTED_PROXIES=
REQUEST_RATE_LIMIT_RPS=2
REQUEST_RATE_LIMIT_BURST=10
ENABLE_METRICS=true
NOTIFICATION_TIMEOUT_SECONDS=10
MODEL_MANIFEST_PATH=/app/config/model-manifest.example.json
# Only one service should run DB migrations in production.
# 生产环境中建议只有一个服务负责执行数据库迁移。
AUTO_MIGRATE_ON_START=true

# Downstream service URLs used by the Go worker.
# Go Worker 调用下游服务时使用的地址。
ML_SERVICE_URL=http://ml-service:8000

# Translation settings / 翻译配置
# TRANSLATION_PROVIDER options / 可选值:
# - mock: no external API required; best for smoke tests
#   不需要外部翻译 API，最适合先跑通流程
# - openai_compatible: requires OPENAI_BASE_URL, OPENAI_API_KEY, OPENAI_MODEL
#   使用 OpenAI 兼容接口，必须填写下面三个字段
TRANSLATION_PROVIDER=mock
# Example OPENAI_BASE_URL values / OPENAI_BASE_URL 示例:
# - https://api.openai.com/v1
# - your OpenAI-compatible gateway / proxy / self-hosted endpoint ending in /v1
# - 你自己的兼容 OpenAI 的网关 / 代理 / 自部署地址，通常以 /v1 结尾
OPENAI_BASE_URL=
OPENAI_API_KEY=
OPENAI_MODEL=
# Lower temperature is usually better for stable, length-aware translation.
# 温度越低通常越稳定，也更适合长度可控的翻译。
OPENAI_TEMPERATURE=0.2
OPENAI_TIMEOUT_SECONDS=90

# Runtime tools expected inside the container images.
# 容器内预期存在的运行工具。
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# ML service backend selection / ML 服务后端选择
# ML_SEPARATOR_BACKEND options / 可选值:
# - ffmpeg_stub: only prepares / extracts audio; no real vocal separation
#   只做音频准备 / 提取，不做人声伴奏真实分离
# - demucs: real vocal / BGM separation; requires ML_PYTHON_EXTRAS=real
#   真实人声 / 伴奏分离，需要安装 heavy 依赖
ML_SEPARATOR_BACKEND=ffmpeg_stub
# ML_ASR_BACKEND options / 可选值:
# - mock: placeholder transcription or sidecar-driven text for smoke tests
#   占位转写；适合烟测或配合 sidecar 文本
# - faster_whisper: real ASR with word timestamps; requires ML_PYTHON_EXTRAS=real
#   真实 ASR，支持词级时间戳
ML_ASR_BACKEND=mock
# ML_VAD_BACKEND options / 可选值:
# - none: disable pyannote / 不启用 pyannote
# - pyannote: real diarization / VAD; requires ML_PYTHON_EXTRAS=real and token
#   真实说话人分离 / VAD，需要 token
ML_VAD_BACKEND=none
# ML_TTS_BACKEND options / 可选值:
# - silence: write silent placeholder wav files / 生成静音占位 wav
# - indextts2: call your IndexTTS2 endpoint or command / 调用你的 IndexTTS2
ML_TTS_BACKEND=silence

# Limit concurrent ML work in the Python service.
# Python ML 服务允许的并发任务数；显存紧张时建议保持 1。
GPU_CONCURRENCY=1

# Used only when ML_ASR_BACKEND=faster_whisper.
# 仅在 faster_whisper 模式下生效。
FASTER_WHISPER_MODEL=small

# Used only when ML_VAD_BACKEND=pyannote.
# 仅在 pyannote 模式下生效。
PYANNOTE_AUTH_TOKEN=
PYANNOTE_PIPELINE=pyannote/speaker-diarization-3.1

# Used only when ML_TTS_BACKEND=indextts2.
# 仅在 indextts2 模式下生效。
# Choose one integration mode / 二选一:
# - HTTP mode: set INDEXTTS2_ENDPOINT (+ API key/model if your service needs them)
#   HTTP 模式：填写 INDEXTTS2_ENDPOINT，必要时再填 API key / model
# - Command mode: set INDEXTTS2_COMMAND
#   命令模式：填写 INDEXTTS2_COMMAND
INDEXTTS2_ENDPOINT=
INDEXTTS2_API_KEY=
INDEXTTS2_MODEL=
# Example command template / 命令模板示例:
# python run_tts.py --text "{text}" --duration "{duration}" --output "{output}"
INDEXTTS2_COMMAND=

# Default audio settings for generated / intermediate wav files.
# 生成音频和中间 wav 文件的默认采样设置。
DEFAULT_SAMPLE_RATE=24000
DEFAULT_CHANNELS=1

# Docker build toggle for optional heavy Python dependencies.
# Docker 构建时用于控制是否安装重型 Python 依赖。
# - empty: lightweight image for smoke tests
#   空值：轻量镜像，适合烟测
# - real: installs model-related packages such as demucs / faster-whisper / pyannote
#   real：安装 demucs / faster-whisper / pyannote 等真实模型依赖
# If you change this value, rebuild the ml-service image.
# 修改这个值后，需要重新构建 ml-service 镜像。
ML_PYTHON_EXTRAS=
