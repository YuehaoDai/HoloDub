{
  "name": "holodub-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx,vue}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,vue}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,vue,json,css}\""
  },
  "dependencies": {
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "wavesurfer.js": "^7.12.7"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "autoprefixer": "^10.5.0",
    "eslint": "^10.4.0",
    "eslint-plugin-vue": "^10.9.1",
    "postcss": "^8.4.38",
    "prettier": "^3.3.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.9"
  }
}
