{
  "name": "holodub-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx,vue}\"",
    "lint:fix": "eslint \"src/**/*.{ts,tsx,vue}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,vue,json,css}\""
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "wavesurfer.js": "^7.12.0"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.10.0",
    "eslint-plugin-vue": "^9.28.0",
    "postcss": "^8.4.38",
    "prettier": "^3.3.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.0.0"
  }
}
